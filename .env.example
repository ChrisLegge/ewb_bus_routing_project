# ── Transport for West Midlands GTFS API ──────────────────────────
# Register free at https://api-portal.tfwm.org.uk/ to obtain credentials.
# Used by scripts/fetch_gtfs.py to download the live Ladywood timetable.
TFWM_APP_ID=your_app_id_here
TFWM_APP_KEY=your_app_key_here

# ── Dashboard server ───────────────────────────────────────────────
# CORS origin allowed to call the API in development (Vite dev server).
DASHBOARD_DEV_ORIGIN=http://localhost:5173

# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.
